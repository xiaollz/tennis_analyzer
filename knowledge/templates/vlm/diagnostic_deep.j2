  {% if node.get("description") %}{{ node["description"][:200] }}{% endif %}
  {% if node.get("vlm_features") %}VLM特征: {{ node["vlm_features"] | join("; ") }}{% endif %}
{% endif %}
{% endfor %}
{% endif %}
