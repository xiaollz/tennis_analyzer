  "concepts": [
    {
      "id": "outward_throwing_motion",
      "name": "Outward Throwing Motion",
      "name_zh": "向外投掷意识",
      "aliases": [],
      "category": "technique",
      "sources": [
        "ftt"
      ],
      "description": "击球时不是向上或向前拍打，而是将球拍向身体的击球侧（右手球员向右，左手球员向左）“扔”出去。",
      "vlm_features": [],
      "muscles_involved": [],
      "active_or_passive": null,
      "confidence": 0.8
    },
    {
      "id": "lower_contact_zone_drill",
      "name": "Lower Contact Zone Drill",
      "name_zh": "低位接触点练习",
      "aliases": [],
      "category": "drill",
      "sources": [
        "ftt"
      ],
      "description": "为了打破“必须打过网”的心理负担，在网前进行高压练习，喂球高度比发球抛球低，重点在于触发纯粹的投掷动作。",
      "vlm_features": [],
      "muscles_involved": [],
      "active_or_passive": null,
      "confidence": 0.8
    },
    {
      "id": "trunk_leaning",
      "name": "Trunk Leaning",
      "name_zh": "躯干倾斜调节",
      "aliases": [],
      "category": "technique",
      "sources": [
        "ftt"
      ],
      "description": "当球离身体太近（被挤到）时，通过向后或向侧面倾斜躯干来创造空间，以维持“向外投掷”的力臂。",
      "vlm_features": [],
      "muscles_involved": [],
      "active_or_passive": null,
      "confidence": 0.8
    },
    {
      "id": "nesting_the_racket",
      "name": "Nesting the Racket",
      "name_zh": "握拍嵌套",
      "aliases": [],
      "category": "technique",
      "sources": [
        "ftt"
      ],
      "description": "球拍应深嵌在手掌的“V型槽”中，并贴合食指根部的掌心位置。",
      "vlm_features": [],
      "muscles_involved": [],
      "active_or_passive": null,
      "confidence": 0.8
    },
    {
      "id": "bottom_fingers_release",
      "name": "Bottom Fingers Release",
      "name_zh": "手指引导/放松",
      "aliases": [],
      "category": "technique",
      "sources": [
        "ftt"
      ],
      "description": "在准备阶段，手掌下方的几个手指可以稍微离开拍柄，仅靠食指和拇指区域感知球拍，以确保挥拍开始时的极度放松。",
      "vlm_features": [],
      "muscles_involved": [],
      "active_or_passive": null,
      "confidence": 0.8
    },
    {
      "id": "external_shoulder_rotation_elbow_penetration",
