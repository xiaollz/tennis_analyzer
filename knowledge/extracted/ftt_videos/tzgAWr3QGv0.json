  "concepts": [
    {
      "id": "press",
      "name": "Press",
      "name_zh": "胸部压迫",
      "aliases": [],
      "category": "technique",
      "sources": [
        "ftt"
      ],
      "description": "在挥拍早期，利用胸大肌的力量防止手臂滞后（Lag）于躯干，强制手臂随转体向前移动。关键点是手肘相对于躯干不应向后摆动。",
      "vlm_features": [],
      "muscles_involved": [],
      "active_or_passive": null,
      "confidence": 0.8
    },
    {
      "id": "prepare_your_hand_lower",
      "name": "Prepare Your Hand Lower",
      "name_zh": "更低的手部准备",
      "aliases": [],
      "category": "technique",
      "sources": [
        "ftt"
      ],
      "description": "辛纳不采用高大的、依赖重力的引拍环形，而是直接将手部准备在击球点的高度（通常是腰部高度）。这简化了挥拍轨迹。",
      "vlm_features": [],
      "muscles_involved": [],
      "active_or_passive": null,
      "confidence": 0.8
    },
    {
      "id": "abbreviated_swing",
      "name": "Abbreviated Swing",
      "name_zh": "简洁胜过冗长",
      "aliases": [],
      "category": "technique",
      "sources": [
        "ftt"
      ],
      "description": "辛纳的动作非常紧凑。较短的引拍路径可以牺牲极少的力量，换取极大的控球精度。",
      "vlm_features": [],
      "muscles_involved": [],
      "active_or_passive": null,
      "confidence": 0.8
    },
    {
      "id": "doublebend_athleticism",
      "name": "Double-Bend Athleticism",
      "name_zh": "“双弯曲”运动员姿态",
      "aliases": [],
      "category": "technique",
      "sources": [
        "ftt"
      ],
      "description": "保持髋部和膝盖的同时弯曲。这不仅降低了重心和引拍高度，还为“力量脉冲”做好了肌肉储备。",
      "vlm_features": [],
      "muscles_involved": [],
      "active_or_passive": null,
      "confidence": 0.8
    },
    {
      "id": "concrete_vs_sand",
      "name": "Concrete vs Sand",
      "name_zh": "“混凝土 vs 沙子”",
      "aliases": [],
      "category": "technique",
      "sources": [
        "ftt"
      ],
      "description": "如果正手不是从触球点倒着推导建立的，就像建立在沙子上；辛纳的正手则是建立在触球直觉的“混凝土”基座上，因此极为稳固。",
      "vlm_features": [],
      "muscles_involved": [],
      "active_or_passive": null,
      "confidence": 0.8
    },
