{
  "video_id": "7_JPqhG4G64",
  "concepts": [
    {
      "id": "center_of_the_cone",
      "name": "Center of the Cone",
      "name_zh": "圆锥区域防守位",
      "aliases": [],
      "category": "technique",
      "sources": [
        "ftt"
      ],
      "description": "击球后，球员必须迅速移动到对手所有可能回球角度所形成的“圆锥区域”的中轴线上，而不是简单地回到球场正中心。",
      "vlm_features": [],
      "muscles_involved": [],
      "active_or_passive": null,
      "confidence": 0.8
    },
    {
      "id": "intentional_active_recovery",
      "name": "Intentional, Active Recovery",
      "name_zh": "刻意且积极的复位",
      "aliases": [],
      "category": "technique",
      "sources": [
        "ftt"
      ],
      "description": "复位不仅仅是走动，而是一种带有明确防守目标的冲刺或快速移动，视频称之为“移动步”（The Move step）。",
      "vlm_features": [],
      "muscles_involved": [],
      "active_or_passive": null,
      "confidence": 0.8
    },
    {
      "id": "attention_pattern_switch",
      "name": "Attention Pattern Switch",
      "name_zh": "注意模式切换",
      "aliases": [],
      "category": "technique",
      "sources": [
        "ftt"
      ],
      "description": "职业选手在击球后会立即从“观察自己击球”切换到“准备拦截对手回球”的积极模式，而不是保持闲散。",
      "vlm_features": [],
      "muscles_involved": [],
      "active_or_passive": null,
      "confidence": 0.8
    },
    {
      "id": "continuous_interception",
      "name": "Continuous Interception",
      "name_zh": "持续拦截意识",
      "aliases": [],
      "category": "technique",
      "sources": [
        "ftt"
      ],
      "description": "在球真正落地或死球之前，大脑要始终保持“我要去拦截并击打下一颗球”的指令，直到视觉确认得分结束。",
      "vlm_features": [],
      "muscles_involved": [],
      "active_or_passive": null,
      "confidence": 0.8
    },
    {
      "id": "visual_confirmation",
      "name": "Visual Confirmation",
      "name_zh": "视觉确认",
      "aliases": [],
      "category": "technique",
      "sources": [
        "ftt"
      ],
      "description": "在没有亲眼看到球出界或挂网之前，绝对不停止脚步或改变注意模式。",
      "vlm_features": [],
      "muscles_involved": [],
      "active_or_passive": null,
      "confidence": 0.8
    },
    {
      "id": "the_lingering_gaze",
      "name": "The Lingering Gaze",
      "name_zh": "持续凝视",
      "aliases": [],
      "category": "technique",
      "sources": [
        "ftt"
      ],
      "description": "即使感觉球会出界，目光也要紧随网球，直到它完全离开比赛区域。",
      "vlm_features": [],
      "muscles_involved": [],
      "active_or_passive": null,
      "confidence": 0.8
    },
    {
      "id": "postprocessing",
      "name": "Post-processing",
      "name_zh": "“后期处理”",
      "aliases": [],
      "category": "technique",
      "sources": [
        "ftt"
      ],
      "description": "批评业余选手在击球后像电脑渲染一样在脑中复盘上一球（“这球感觉不错”或“这球打得真烂”），这会干扰对下一球的准备。",
      "vlm_features": [],
      "muscles_involved": [],
      "active_or_passive": null,
      "confidence": 0.8
    },
    {
      "id": "lala_land",
      "name": "Lala land",
      "name_zh": "“乐乐镇/幻境”",
      "aliases": [],
      "category": "technique",
      "sources": [
        "ftt"
      ],
      "description": "业余选手在打出臭球后，陷入自怨自艾或思考技术细节的状态，脱离了比赛现实。",
      "vlm_features": [],
      "muscles_involved": [],
      "active_or_passive": null,
      "confidence": 0.8
    },
    {
