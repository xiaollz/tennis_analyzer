  "concepts": [
    {
      "id": "defensive_slice_selection",
      "name": "Defensive Slice Selection",
      "name_zh": "防守中的削球选择",
      "aliases": [],
      "category": "biomechanics",
      "sources": [
        "ftt"
      ],
      "description": "当被动奔跑救球时，不要尝试高难度的削球（如费德勒式的低平切削）。建议采用“高轨迹削球”（Chip Floater），让球越过球网较高位置，虽然球速慢且不深，但能确保极高的过网率。",
      "vlm_features": [],
      "muscles_involved": [],
      "active_or_passive": null,
      "confidence": 0.8
    },
    {
      "id": "passing_shot_targeting",
      "name": "Passing Shot Targeting",
      "name_zh": "穿越球的目标选择",
      "aliases": [],
      "category": "technique",
      "sources": [
        "ftt"
      ],
      "description": "面对上网对手，不要追求边线或极端角度。技术要点是：**对准球网中心发力击打**。这迫使对手必须打出一个高质量的截击才能得分，而非寄希望于你失误。",
      "vlm_features": [],
      "muscles_involved": [],
      "active_or_passive": null,
      "confidence": 0.8
    },
