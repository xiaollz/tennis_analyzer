    {
      "id": "racket_overtaking_hand",
      "name": "Racket Overtaking Hand",
      "name_zh": "球拍超越手部",
      "aliases": [],
      "category": "technique",
      "sources": [
        "ftt"
      ],
      "description": "在击球前约 0.04 秒，球拍头部会迅速摆动并超越手部，这是弹性势能转化为动能的关键点。",
      "vlm_features": [],
      "muscles_involved": [],
      "active_or_passive": null,
      "confidence": 0.8
    },
    {
      "id": "compensatory_contraction",
      "name": "Compensatory Contraction",
      "name_zh": "代偿性收紧",
      "aliases": [],
      "category": "biomechanics",
      "sources": [
        "ftt"
      ],
      "description": "如果时机错误（释放过早），大脑会试图通过收缩手腕伸展肌（wrist extenders）来强行控制拍面角度。这种“硬拉”动作不仅降低球速，还是导致网球肘等伤病的主要原因。",
      "vlm_features": [],
      "muscles_involved": [],
      "active_or_passive": null,
      "confidence": 0.8
    },
    {
      "id": "the_spring",
      "name": "The Spring",
      "name_zh": "核心比喻——“弹簧”",
      "aliases": [],
      "category": "drill",
      "sources": [
        "ftt"
      ],
      "description": "将手腕的延迟（Lag）和拉伸比作压缩的弹簧。训练的目标是让这个弹簧在撞击球的那一刻才弹出。",
      "vlm_features": [],
      "muscles_involved": [],
      "active_or_passive": null,
      "confidence": 0.8
    },
